#!/bin/bash

# Git hook to validate conventional commit messages
# This ensures all commits follow the conventional commit format

commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Conventional commit regex pattern
# Format: <type>(<scope>): <subject>
# Optional: <body> and <footer>
conventional_commit_pattern='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+'

# Check if commit message matches conventional commit format
if ! echo "$commit_msg" | grep -qE "$conventional_commit_pattern"; then
    echo "❌ Invalid commit message format!"
    echo ""
    echo "Commit message must follow Conventional Commits format:"
    echo "  <type>(<scope>): <subject>"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
    echo ""
    echo "Examples:"
    echo "  feat(turbo_firestore_api): add batch update support"
    echo "  fix(turbo_forms): resolve validation error"
    echo "  docs: update README with examples"
    echo ""
    echo "Your message:"
    echo "  $commit_msg"
    echo ""
    exit 1
fi

exit 0

