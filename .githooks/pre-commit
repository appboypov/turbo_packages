#!/bin/bash

# Git hook to run checks before committing
# Runs format check and analyze to ensure code quality

set -e

echo "🔍 Running pre-commit checks..."

# Check if melos is available
if ! command -v melos &> /dev/null; then
    echo "⚠️  Melos not found. Install with: dart pub global activate melos"
    echo "Skipping pre-commit checks..."
    exit 0
fi

# Run format check
echo "📝 Checking code formatting..."
if ! melos run format:check; then
    echo "❌ Code formatting check failed!"
    echo "Run 'melos run format' to fix formatting issues."
    exit 1
fi

# Run analyze
echo "🔎 Running code analysis..."
if ! melos run analyze; then
    echo "❌ Code analysis failed!"
    echo "Fix analyzer issues before committing."
    exit 1
fi

echo "✅ Pre-commit checks passed!"
exit 0

